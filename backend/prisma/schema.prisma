generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String      @id @default(uuid())
  name         String
  slug         String      @unique
  description  String
  price        Float
  comparePrice Float?
  costPrice    Float       @default(0)
  images       String[]
  stripeImage  String?
  orderImage   String?
  variants     Json?
  supplierUrl  String?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orders       OrderItem[]
  bundleItems  BundleItem[]
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     Int         @unique @default(autoincrement())
  status          OrderStatus @default(PENDING)
  customerEmail   String
  customerName    String
  customerPhone   String    @default("")
  shippingAddress Json
  items           OrderItem[]
  total           Float
  stripeSessionId String?     @unique
  stripePaymentId String?
  trackingNumber  String?
  trackingUrl     String?
  supplierOrderId String?
  supplierUrl     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  variant    String?
  bundleSlug String?

  @@index([orderId])
  @@index([productId])
}

model Bundle {
  id           String       @id @default(uuid())
  slug         String       @unique
  label        String
  description  String       @default("")
  price        Float
  comparePrice Float?
  badge        String?
  position     Int          @default(0)
  active       Boolean      @default(true)
  items        BundleItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model BundleItem {
  id        String  @id @default(uuid())
  bundleId  String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@index([bundleId])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
